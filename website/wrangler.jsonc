{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lunaticchat-docs",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "dist"
  },
  "routes": [
    { "pattern": "lc.m1sk9.dev", "custom_domain": true }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
